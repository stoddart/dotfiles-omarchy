# User-specific binaries (scripts, pip-installed tools, etc.)
# This ensures local tools take precedence over system ones.
export PATH="$HOME/.local/bin:$PATH"

# If not running interactively, don't do anything (leave this at the top of this file)
[[ $- != *i* ]] && return

# All the default Omarchy aliases and functions
# (don't mess with these directly, just overwrite them here!)
source ~/.local/share/omarchy/default/bash/rc

# Add your own exports, aliases, and functions here.

# Clipboard aliases for Wayland
alias copy='wl-copy'
alias paste='wl-paste'

# Make an alias for invoking commands you use constantly
# alias p='python'

# Laravel installer (Composer global bin)
export PATH="$HOME/.config/composer/vendor/bin:$PATH"

# Load secret API keys
[ -f ~/.env.secrets ] && source ~/.env.secrets

# Cargo (Rust) binaries
export PATH="$HOME/.cargo/bin:$PATH"

# Go binaries
export PATH="$HOME/go/bin:$PATH"

# Zoxide - smarter cd
eval "$(zoxide init bash)"

# Broot integration: allows the 'br' command to change the shell's
# working directory upon exit.
source /home/daniel/.config/broot/launcher/bash/br

# Usenet/NNTP server
export NNTPSERVER=news.eternal-september.org

# --- Application Aliases ---

# PyChess: Silence GTK/asyncio teardown warnings on exit.
# These errors are harmless but clutter the terminal on modern Python versions.
alias pychess='/usr/bin/pychess 2>/dev/null'
